# 必填：OpenAI API Key。没有时，系统会返回一份演示报告，方便先部署测试。
OPENAI_API_KEY=

# 可选：模型名。留空默认使用 gpt-4.1-mini。
OPENAI_MODEL=gpt-4.1-mini

# 必填：在 PayPal 后台创建两个 Payment Link 后粘贴到这里。
NEXT_PUBLIC_PAYPAL_BASIC_LINK=https://www.paypal.com/ncp/payment/YOUR_BASIC_LINK
NEXT_PUBLIC_PAYPAL_PRO_LINK=https://www.paypal.com/ncp/payment/YOUR_PRO_LINK

# 可选：如果你有 Zapier/Make/飞书/Airtable Webhook，可把订单线索同步过去。
LEAD_WEBHOOK_URL=

# 可选：展示给用户的联系邮箱。
NEXT_PUBLIC_SUPPORT_EMAIL=you@example.com

# PayPal Checkout automatic verification
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=live
PAYPAL_CURRENCY=USD
NEXT_PUBLIC_PAYPAL_CURRENCY=USD
PAYMENT_TOKEN_SECRET=
